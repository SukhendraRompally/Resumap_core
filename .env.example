# Azure OpenAI key used by both our Python code and the
# Stagehand server process.  The library sets MODEL_API_KEY for its
# client but the internal Node backend still expects OPENAI_API_KEY
# (same value) so we export both below.
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_VERSION=2024-02-01
REPLIT_BASE_URL=https://your-replit-app.site
WEBHOOK_SECRET=your-webhook-secret-here
TAILOR_BASE_URL=http://localhost:8000
TAILOR_SECRET=your-tailor-secret-here
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# You can provide a separate, regular OpenAI key for the executor
# if you prefer not to use your Azure credentials for browser automation.
# When present the executor will ignore the Azure settings above and use
# EXECUTOR_OPENAI_KEY instead (e.g. for access to gpt-4o-mini as a free
# model).
# EXECUTOR_OPENAI_KEY=your-openai-key-here
# EXECUTOR_MODEL=gpt-4o-mini          # optional; defaults to this anyway

# Optional Azure OpenAI settings used by Stagehand's server process.
# These mirror the variables used by the OpenAI/azure SDK:
# OPENAI_API_BASE=https://your-resource.cognitiveservices.azure.com/
# OPENAI_API_TYPE=azure
# OPENAI_API_VERSION=2024-02-01

# Path to a local Chrome/Chromium binary for Stagehand's browser automation
# Example (Playwright-managed):
# CHROME_PATH=/home/azureuser/.cache/ms-playwright/chromium-1208/chrome-linux64/chrome
